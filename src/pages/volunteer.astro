---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h2>Volunteer with us: </h2>
      <p>Want to get involved? Here are some of the ways you can help support our mission:</p>

<div class="google-form-wrapper">
  <iframe src=https://docs.google.com/forms/d/e/1FAIpQLSeHaonlFYJebnX6ua8M1NRoLQafZ-y3McCdbn8u8QsA582RQA/viewform?embedded=true" frameborder="0" marginheight="0" marginwidth="0">Loading…</iframe>
</div>



			<p>
				We look forward to seeing or hearing from you one day!
			</p>
		</main>
		<Footer />
	</body>
</html>
<style>
.google-form-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 150%; /* Adjust based on form height */
  height: 0;
  overflow: hidden;
}

.google-form-wrapper iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 0;
}
</style>
