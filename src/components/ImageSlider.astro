---
const { images } = Astro.props;
---
<div class="slider" data-slider>
  <div class="slides">
    {images.map((img) => (
      <img src={img.src} alt={img.alt} loading="lazy" />
    ))}
  </div>

  <!-- 👇 Navigation buttons -->
  <button class="nav prev">‹</button>
  <button class="nav next">›</button>
</div>

<style>
.slider {
  position: relative; /* 👈 required for buttons */
  height: min(60vh, 500px);
  max-width: 1200px;
  margin: auto;
  overflow: hidden;
  border-radius: 12px;
  touch-action: pan-y;
  cursor: grab;
}

.slides {
  display: flex;
  transition: transform 0.6s ease-in-out;
}

.slider:active {
  cursor: grabbing;
}

.slides img {
  width: 100%;
  flex-shrink: 0;
  object-fit: cover;
}

/* 👇 Navigation buttons */
.nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.4);
  color: white;
  border: none;
  font-size: 2rem;
  padding: 0.5rem 0.75rem;
  cursor: pointer;
  border-radius: 8px;
}

.prev { left: 10px; }
.next { right: 10px; }

.nav:hover {
  background: rgba(0,0,0,0.6);
}
</style>

<script is:inline>
  const sliders = document.querySelectorAll("[data-slider]");

  sliders.forEach((sliderRoot) => {
    const slidesTrack = sliderRoot.querySelector(".slides");
    const slides = slidesTrack.children;
    const prevBtn = sliderRoot.querySelector(".prev");
    const nextBtn = sliderRoot.querySelector(".next");

    let index = 0;
    let interval;

    let startX = 0;
    let endX = 0;
    
    const threshold = 50; // minimum swipe distance (px)
    
    // Touch start
    sliderRoot.addEventListener("touchstart", (e) => {
      startX = e.touches[0].clientX;
    });
    
    // Touch move (optional but helps accuracy)
    sliderRoot.addEventListener("touchmove", (e) => {
      endX = e.touches[0].clientX;
    });
    
    // Touch end
    sliderRoot.addEventListener("touchend", () => {
      const distance = startX - endX;
    
      if (Math.abs(distance) > threshold) {
        if (distance > 0) {
          // Swiped left → next slide
          nextSlide();
        } else {
          // Swiped right → previous slide
          prevSlide();
        }
    
        // Reset autoplay after interaction
        stopAutoPlay();
        startAutoPlay();
      }
    
      // Reset values
      startX = 0;
      endX = 0;
    });

    function updateSlide() {
      slidesTrack.style.transform = `translateX(-${index * 100}%)`;
    }

    function nextSlide() {
      index = (index + 1) % slides.length;
      updateSlide();
    }

    function prevSlide() {
      index = (index - 1 + slides.length) % slides.length;
      updateSlide();
    }

    function startAutoPlay() {
      interval = setInterval(nextSlide, 4000);
    }

    function stopAutoPlay() {
      clearInterval(interval);
    }

    // Button controls
    nextBtn.addEventListener("click", () => {
      nextSlide();
      stopAutoPlay();
      startAutoPlay();
    });

    prevBtn.addEventListener("click", () => {
      prevSlide();
      stopAutoPlay();
      startAutoPlay();
    });

    // Pause on hover
    sliderRoot.addEventListener("mouseenter", stopAutoPlay);
    sliderRoot.addEventListener("mouseleave", startAutoPlay);

    // Start
    startAutoPlay();
  });
</script>

