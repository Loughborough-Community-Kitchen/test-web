---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  image?: string;
}

const { title, description, href, icon, image } = Astro.props;
---

<a href={href} class="card">
  {image ? (
    <img src={image} alt={title} class="card-image" />
  ) : (
    icon && <div class="icon">{icon}</div>
  )}

  <div class="card-content">
    <h3>{title}</h3>
    <p>{description}</p>
    <span class="cta">Learn more →</span>
  </div>
</a>

<style>
  .card {
    display: block;
    width: 100%;
    max-width: 100%;
    background-color: #FFF9E6; /* 👈 matches your theme */
    border-radius: 16px;
    border: 1px solid #e5e7eb;
    text-decoration: none;
    color: #111827;
  
    overflow: hidden; /* 👈 important for image rounding */
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  }
  
  .card-image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }
  
  .card-content {
    padding: 1.5rem;
  }

  .icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }

  p {
    margin: 0;
    line-height: 1.5;
    color: #4b5563;
  }

  .cta {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 600;
    color: #2563eb;
  }
</style>
